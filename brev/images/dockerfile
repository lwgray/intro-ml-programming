# syntax=docker/dockerfile:1
#
# One dockerfile, five published images (build with --target):
#
#   part1        weeks 1-5   CPU   sklearn stack + baked datasets
#   part2        weeks 6-7   CPU   + torch (CPU) + Keras 3 + baked Keras datasets
#   vision       weeks 8-9   GPU   + pretrained backbones, CLIP, cats-vs-dogs
#   transformers week 10     GPU   + DistilBERT/GPT-2/T5 + AG News/IMDB
#   genai        week 11     GPU   + Phi-3-mini, Qwen2.5, Stable Diffusion 1.5
#
# Build context is the repo root, e.g.:
#   docker build -f brev/images/dockerfile --target part1 -t ghcr.io/lwgray/intro-ml-part1:latest .
#
# Layer order matters: dependencies, then model/data prefetch, then COPY of the
# repo — so editing a notebook never re-downloads gigabytes of weights.

# ---------------------------------------------------------------------------
# CPU base: weeks 1-7
# ---------------------------------------------------------------------------
FROM python:3.12-slim-bookworm AS cpu-base

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_ROOT_USER_ACTION=ignore \
    MPLCONFIGDIR=/tmp/matplotlib_cache \
    SCIKIT_LEARN_DATA=/opt/caches/scikit_learn_data \
    SEABORN_DATA=/opt/caches/seaborn-data \
    KERAS_HOME=/opt/caches/keras \
    HF_HOME=/opt/caches/huggingface

RUN apt-get update -y \
 && apt-get install -y --no-install-recommends \
    git \
    git-lfs \
    curl \
    ca-certificates \
    gosu \
    sudo \
 && apt-get clean -y \
 && rm -rf /var/lib/apt/lists/*

# Enable passwordless sudo for all users and pass through environment and path
RUN echo 'ALL ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers \
 && sed -i -e 's/^Defaults\s*env_reset/Defaults !env_reset/' -e 's/^Defaults\s*secure_path=/#&/' /etc/sudoers

COPY brev/images/requirements-common.txt /opt/
RUN pip install --no-cache-dir -r /opt/requirements-common.txt

# Disable unnecessary default Jupyter extensions
RUN python -m jupyter labextension disable "@jupyterlab/apputils-extension:announcements" \
 && python -m jupyter labextension disable "@jupyterlab/console-extension:tracker"

# ---------------------------------------------------------------------------
# part1: weeks 1-5
# ---------------------------------------------------------------------------
FROM cpu-base AS part1

COPY brev/images/prefetch-part1.py /opt/
RUN python /opt/prefetch-part1.py \
 && chmod -R a+rwX /opt/caches /opt/data

COPY --chmod=0777 . /intro-ml-programming

ENTRYPOINT ["/intro-ml-programming/brev/entrypoint.bash", "jupyter"]

# ---------------------------------------------------------------------------
# part2: weeks 6-7
# ---------------------------------------------------------------------------
FROM cpu-base AS part2

RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch

COPY brev/images/requirements-keras.txt /opt/
RUN pip install --no-cache-dir -r /opt/requirements-keras.txt

ENV KERAS_BACKEND=torch

COPY brev/images/prefetch-part2.py /opt/
RUN python /opt/prefetch-part2.py \
 && chmod -R a+rwX /opt/caches

COPY --chmod=0777 . /intro-ml-programming

ENTRYPOINT ["/intro-ml-programming/brev/entrypoint.bash", "jupyter"]

# ---------------------------------------------------------------------------
# GPU base: weeks 8-11
# ---------------------------------------------------------------------------
FROM nvidia/cuda:12.6.3-base-ubuntu24.04 AS gpu-base

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_ROOT_USER_ACTION=ignore \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    MPLCONFIGDIR=/tmp/matplotlib_cache \
    SCIKIT_LEARN_DATA=/opt/caches/scikit_learn_data \
    SEABORN_DATA=/opt/caches/seaborn-data \
    KERAS_HOME=/opt/caches/keras \
    HF_HOME=/opt/caches/huggingface \
    KERAS_BACKEND=torch

# Ubuntu 24.04 ships Python 3.12
RUN apt-get update -y \
 && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    git \
    git-lfs \
    curl \
    ca-certificates \
    gosu \
    sudo \
 && apt-get clean -y \
 && rm -rf /var/lib/apt/lists/* \
 && rm -f /usr/lib/python3.*/EXTERNALLY-MANAGED \
 && ln -sf /usr/bin/python3 /usr/local/bin/python

RUN echo 'ALL ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers \
 && sed -i -e 's/^Defaults\s*env_reset/Defaults !env_reset/' -e 's/^Defaults\s*secure_path=/#&/' /etc/sudoers

# CUDA-enabled torch from PyPI (wheels bundle the CUDA runtime)
RUN pip install --no-cache-dir torch

COPY brev/images/requirements-common.txt brev/images/requirements-gpu.txt /opt/
RUN pip install --no-cache-dir -r /opt/requirements-common.txt -r /opt/requirements-gpu.txt

RUN python -m jupyter labextension disable "@jupyterlab/apputils-extension:announcements" \
 && python -m jupyter labextension disable "@jupyterlab/console-extension:tracker"

# ---------------------------------------------------------------------------
# vision: weeks 8-9
# ---------------------------------------------------------------------------
FROM gpu-base AS vision

COPY brev/images/prefetch-vision.py /opt/
RUN python /opt/prefetch-vision.py \
 && chmod -R a+rwX /opt/caches

COPY --chmod=0777 . /intro-ml-programming

ENTRYPOINT ["/intro-ml-programming/brev/entrypoint.bash", "jupyter"]

# ---------------------------------------------------------------------------
# transformers: week 10
# ---------------------------------------------------------------------------
FROM gpu-base AS transformers

COPY brev/images/prefetch-week10.py /opt/
RUN python /opt/prefetch-week10.py \
 && chmod -R a+rwX /opt/caches

COPY --chmod=0777 . /intro-ml-programming

ENTRYPOINT ["/intro-ml-programming/brev/entrypoint.bash", "jupyter"]

# ---------------------------------------------------------------------------
# genai: week 11
# ---------------------------------------------------------------------------
FROM gpu-base AS genai

COPY brev/images/requirements-genai.txt /opt/
RUN pip install --no-cache-dir -r /opt/requirements-genai.txt

COPY brev/images/prefetch-week11.py /opt/
RUN python /opt/prefetch-week11.py \
 && chmod -R a+rwX /opt/caches

COPY --chmod=0777 . /intro-ml-programming

ENTRYPOINT ["/intro-ml-programming/brev/entrypoint.bash", "jupyter"]
